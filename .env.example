# ── Only ONE thing is strictly required: the control bot token ──────
# Create a bot via @BotFather and paste its token here.
# Everything else (API ID, API Hash, login) is done INSIDE the bot chat
# via the 🔐 Account menu — no redeploy needed.
CONTROL_BOT_TOKEN=123456:your-botfather-token

# Optional: lock the bot to your numeric Telegram id (from @userinfobot).
# If left blank, the FIRST person to /start the bot becomes the owner.
ADMIN_USER_ID=

# ── Optional seed values (you can instead set these in the bot) ─────
# If provided, they pre-fill the Account menu on first boot.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION=

# ── Storage ─────────────────────────────────────────────────────────
# On Railway/Docker, attach a Volume at /data so login + ads persist.
DB_PATH=/data/ad_bot.db
LOG_LEVEL=INFO
